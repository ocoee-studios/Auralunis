{
  "cli": { "version": ">= 12.0.0" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "development-simulator": {
      "extends": "development",
      "ios": { "simulator": true }
    },
    "preview": {
      "distribution": "internal",
      "env": { "EXPO_PUBLIC_FORCE_PREMIUM": "1" }
    },
    "production": { "autoIncrement": true }
  },
  "submit": { "production": {} }
}
